NODE_ENV=development
PORT=8788
DATA_FILE=./data/licenses.json

# Replace every secret before deploying.
ADMIN_API_KEY=replace-with-a-long-random-admin-key
LICENSE_HASH_SECRET=replace-with-a-long-random-license-hash-secret
BILLING_WEBHOOK_SECRET=replace-with-a-long-random-webhook-secret

# Comma-separated exact origins. Add the final extension origin when known.
CORS_ORIGINS=http://localhost:3000,chrome-extension://YOUR_EXTENSION_ID

# OpenAI Responses API. Set OPENAI_MODEL_TIER=quality to use gpt-5.5.
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com
OPENAI_MODEL_TIER=fast
# OPENAI_MODEL=gpt-5.4-mini
OPENAI_REQUEST_TIMEOUT_MS=20000
